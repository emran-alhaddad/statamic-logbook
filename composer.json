{
    "name": "emran-alhaddad/statamic-logbook",
    "description": "Statamic addon for system logs and user audit logs stored in a database, with CP UI, analytics, and CSV export.",
    "type": "statamic-addon",
    "license": "MIT",
    "keywords": ["statamic", "laravel", "logging", "audit", "compliance"],
    "require": {
      "php": "^8.2",
      "statamic/cms": "^5.0",
      "illuminate/support": "^11.0",
      "monolog/monolog": "^3.0"
    },
    "autoload": {
      "psr-4": {
        "EmranAlhaddad\\StatamicLogbook\\": "src/"
      }
    },
    "extra": {
      "laravel": {
        "providers": [
          "EmranAlhaddad\\StatamicLogbook\\LogbookServiceProvider"
        ]
      }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
  }
  